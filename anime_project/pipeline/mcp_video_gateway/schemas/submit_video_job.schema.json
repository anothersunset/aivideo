{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anothersunset/aivideo/schemas/submit_video_job.schema.json",
  "title": "Kage MCP submit_video_job payload",
  "type": "object",
  "required": ["tool", "arguments"],
  "properties": {
    "tool": {
      "const": "submit_video_job"
    },
    "schema": {
      "type": "string"
    },
    "arguments": {
      "type": "object",
      "required": [
        "provider",
        "model",
        "segment",
        "shot_id",
        "chunk_index",
        "duration_seconds",
        "fps",
        "resolution",
        "prompt",
        "expected_chunk_path",
        "expected_final_inbox_path"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "profile_schema": {
          "type": "string"
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "segment": {
          "type": "string",
          "minLength": 1
        },
        "shot_id": {
          "type": "string",
          "minLength": 1
        },
        "chunk_index": {
          "type": "integer",
          "minimum": 1
        },
        "duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "fps": {
          "type": "integer",
          "const": 24
        },
        "resolution": {
          "type": "string",
          "const": "1920x1080"
        },
        "keyframe_path": {
          "type": "string"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "negative_prompt": {
          "type": "string"
        },
        "expected_chunk_path": {
          "type": "string",
          "pattern": "\\.mp4$"
        },
        "expected_final_inbox_path": {
          "type": "string",
          "pattern": "\\.mp4$"
        },
        "safety_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
